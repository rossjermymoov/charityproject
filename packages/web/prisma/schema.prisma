  title             String
  description       String?
  assignedToId      String
  status            String    @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | CANCELLED
  priority          String    @default("MEDIUM")
  dueDate           DateTime?
  completedAt       DateTime?
  relatedContactId  String?
  relatedDonationId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  rule           TaskRule? @relation("TaskRuleAutoTasks", fields: [ruleId], references: [id], onDelete: SetNull)
  assignedTo     User      @relation("AutoTaskAssignee", fields: [assignedToId], references: [id], onDelete: Cascade)
  relatedContact Contact?  @relation("AutoTaskContact", fields: [relatedContactId], references: [id], onDelete: SetNull)

  @@index([ruleId])
  @@index([assignedToId])
  @@index([status])
  @@index([relatedContactId])
}
