generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// SYSTEM SETTINGS (singleton — one row)
// ============================================

model SystemSettings {
  id                    String @id @default("default")
  financialYearEndMonth Int    @default(3) // 1=Jan … 12=Dec, default March (UK charity standard)
  financialYearEndDay   Int    @default(31) // day of month

  // ── Annual events targets ──
  eventsIncomeTarget Float? // Annual target income from events e.g. 400000
  eventsCostBudget   Float? // Annual predicted cost budget e.g. 250000
  eventsProfitTarget Float? // Annual profit target

  // ── White-label branding ──
  orgName           String? // Display name (replaces "Parity CRM" in sidebar)
  logoUrl           String? // URL or /uploads/logo.png path for the logo
  primaryColour     String  @default("#C9A84C") // Brand colour (hex) — buttons, links, accents
  sidebarColour     String  @default("#1b3a2d") // Sidebar background colour (hex)
  sidebarTextColour String  @default("#f7f3ec") // Sidebar text colour (hex)

  // ── Collection Tins Mode ──
  // MY_ROUTES = predefined routes assigned to volunteers (larger charities)
  // SUGGESTED_ROUTES = AI-suggested ad-hoc routes based on distance & data (smaller charities)
  collectionMode String @default("SUGGESTED_ROUTES") // MY_ROUTES | SUGGESTED_ROUTES

  // ── Collection Tins — Head Office (route start point) ──
  headOfficeAddress String? // Full address text
  headOfficeLat     Float? // Latitude for route calculations
  headOfficeLng     Float? // Longitude for route calculations

  // ── Catchment Area & Prospects ──
  catchmentPostcodes    String? // JSON array of postcode prefixes e.g. ["SY10","SY11","SY10 1"]
  charityDescription    String? // Free-text paragraph about what the charity does (used in letters/infographics)
  charityWebsite        String? // Charity website URL for AI letter generation
  charityWebsiteSummary String? // AI-generated summary of charity website content (cached)
  googlePlacesApiKey    String? // Google Places API key for prospect finding
  letterheadImage       String? // Base64 data URL of charity letterhead image (PNG/JPEG)

  // ── HMRC Gift Aid Integration ──
  hmrcCharityRef      String? // HMRC Charity Reference (e.g. XR12345)
  hmrcGatewayUser     String? // Government Gateway User ID
  hmrcGatewayPassword String? // Government Gateway Password
  hmrcSenderId        String? // Software Vendor Sender ID
  hmrcEnabled         Boolean @default(false)

  // ── Sage Intacct Integration ──
  sageCompanyId      String? // Sage Intacct Company ID
  sageSenderId       String? // Web Services Sender ID
  sageSenderPassword String? // Sender Password (encrypted)
  sageUserId         String? // User ID for API auth
  sageUserPassword   String? // User Password (encrypted)
  sageEnabled        Boolean @default(false)

  // ── Loqate Integration ──
  loqateApiKey String? // Loqate API key for address verification

  // ── Donor Recognition ──
  goldDonorThreshold Float @default(1000) // Lifetime donation amount (£) to earn Gold Donor status

  updatedAt DateTime @updatedAt
}

model Shop {
  id          String   @id @default(cuid())
  name        String
  address     String?
  city        String?
  postcode    String?
  qrToken     String   @unique // used in the public QR code URL
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation("ShopCreatedBy", fields: [createdById], references: [id])

  @@index([qrToken])
}

// ============================================
// CORE / SHARED
// ============================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("STAFF") // ADMIN | STAFF | VOLUNTEER | DONOR
  contactId    String?  @unique // link to CRM Contact for donors/volunteers
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  isArchived  Boolean   @default(false)
  archivedAt  DateTime?
  mfaEnabled  Boolean   @default(false)
  lastLoginAt DateTime?

  contactsCreated            Contact[]               @relation("CreatedByUser")
  interactionsCreated        Interaction[]           @relation("InteractionCreatedBy")
  notesCreated               Note[]                  @relation("NoteCreatedBy")
  hoursVerified              VolunteerHoursLog[]     @relation("VerifiedByUser")
  assignmentsCreated         Assignment[]            @relation("AssignmentCreatedBy")
  broadcastsCreated          Broadcast[]             @relation("BroadcastCreatedBy")
  broadcastConfirmations     BroadcastResponse[]     @relation("BroadcastConfirmedBy")
  remindersCreated           Reminder[]              @relation("ReminderCreatedBy")
  skillsVerified             VolunteerSkill[]        @relation("SkillVerifiedBy")
  notifications              Notification[]          @relation("NotificationRecipient")
  notificationPreference     NotificationPreference?
  pushDevices                PushDevice[]
  volunteerProfile           VolunteerProfile?       @relation("UserVolunteerProfile")
  auditLogs                  AuditLog[]              @relation("AuditLogUser")
  giftAidCreated             GiftAid[]               @relation("GiftAidCreatedBy")
  donationsCreated           Donation[]              @relation("DonationCreatedBy")
  eventsCreated              Event[]                 @relation("EventCreatedBy")
  campaignsCreated           Campaign[]              @relation("CampaignCreatedBy")
  collectionTinsCreated      CollectionTin[]         @relation("CollectionTinCreatedBy")
  tributeFundsCreated        TributeFund[]           @relation("TributeFundCreatedBy")
  trainingVerified           VolunteerTraining[]     @relation("TrainingVerifiedBy")
  dpiasCreated               Dpia[]                  @relation("DpiaCreatedBy")
  breachesCreated            DataBreach[]            @relation("BreachCreatedBy")
  sarsCreated                SubjectAccessRequest[]  @relation("SarCreatedBy")
  sarsAssigned               SubjectAccessRequest[]  @relation("SarAssignedTo")
  consentRecords             ConsentRecord[]         @relation("ConsentRecordedBy")
  emailProviders             EmailProvider[]         @relation("EmailProviderCreatedBy")
  paymentProvidersCreated    PaymentProvider[]       @relation("PaymentProviderCreatedBy")
  formsCreated               Form[]                  @relation("FormCreatedBy")
  grantsCreated              Grant[]                 @relation("GrantCreatedBy")
  legaciesCreated            Legacy[]                @relation("LegacyCreatedBy")
  casesCreated               CaseRecord[]            @relation("CaseCreatedBy")
  casesAssigned              CaseRecord[]            @relation("CaseAssignedTo")
  giftAidClaimsCreated       GiftAidClaim[]          @relation("GiftAidClaimCreatedBy")
  giftAidClaimsSubmitted     GiftAidClaim[]          @relation("GiftAidClaimSubmittedBy")
  shopsCreated               Shop[]                  @relation("ShopCreatedBy")
  routesCreated              CollectionRoute[]       @relation("RouteCreatedBy")
  runsCreated                CollectionRun[]         @relation("RunCreatedBy")
  tinReturnsProcessed        TinReturn[]             @relation("TinReturnCountedBy")
  automationRules            AutomationRule[]        @relation("AutomationRulesCreated")
  emailTemplates             EmailTemplate[]         @relation("EmailTemplatesCreated")
  linkedContact              Contact?                @relation("UserLinkedContact", fields: [contactId], references: [id])
  savedReports               SavedReport[]           @relation("SavedReportCreatedBy")
  donorOpportunitiesCreated  DonorOpportunity[]      @relation("DonorOpportunitiesCreatedBy")
  donorOpportunitiesAssigned DonorOpportunity[]      @relation("DonorOpportunitiesAssignedTo")
  reconciliationSessions     ReconciliationSession[] @relation("ReconciliationSessionsCreated")
  gasdsClaimsCreated         GasdsClaim[]            @relation("GasdsClaimsCreated")
  partnershipActivities      PartnershipActivity[]   @relation("PartnershipActivityUser")
  savedSegments              SavedSegment[]          @relation("SavedSegmentCreatedBy")
  donationImports            DonationImport[]        @relation("DonationImportCreatedBy")
  pledgesCreated             Pledge[]                @relation("PledgeCreatedBy")
  boardReportsGenerated      BoardReport[]           @relation("BoardReportGeneratedBy")
  financialReportsGenerated  FinancialReport[]       @relation("FinancialReportGeneratedBy")
  webhooksCreated            Webhook[]               @relation("WebhookCreatedBy")
  taskRulesAssignee          TaskRule[]              @relation("TaskRuleAssignee")
  autoTasksAssigned          AutoTask[]              @relation("AutoTaskAssignee")
  bankDocuments              BankDocument[]          @relation("BankDocCreatedBy")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skills               Skill[]
  volunteerDepartments VolunteerDepartment[]
  hoursLogs            VolunteerHoursLog[]
  activityRecords      ActivityRecord[]
  assignments          Assignment[]
  broadcasts           Broadcast[]
  requiredTraining     DepartmentTraining[]
}

model Skill {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  departmentId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department      Department?      @relation(fields: [departmentId], references: [id])
  volunteerSkills VolunteerSkill[]
  broadcastSkills BroadcastSkill[]
}

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  pushEnabled     Boolean  @default(true)
  emailEnabled    Boolean  @default(true)
  smsEnabled      Boolean  @default(false)
  inAppEnabled    Boolean  @default(true)
  broadcastOptIn  Boolean  @default(true)
  quietHoursStart String?
  quietHoursEnd   String?
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// CRM MODULE
// ============================================

model Contact {
  id                     String    @id @default(cuid())
  donorId                Int       @unique @default(autoincrement())
  firstName              String
  lastName               String
  email                  String?
  phone                  String?
  addressLine1           String?
  addressLine2           String?
  city                   String?
  postcode               String?
  country                String?
  type                   String    @default("OTHER") // DEPRECATED - use types[] instead
  types                  String[]  @default([]) // VOLUNTEER | DONOR (multi-select)
  organisationId         String?
  customFields           String? // JSON key-value store for configurable fields
  status                 String    @default("ACTIVE") // ACTIVE | ARCHIVED | DECEASED | ANONYMISED
  consentPost            Boolean   @default(false)
  consentEmail           Boolean   @default(false)
  consentPhone           Boolean   @default(false)
  consentSms             Boolean   @default(false)
  consentUpdatedAt       DateTime?
  emailOptIn             Boolean   @default(true)
  smsOptIn               Boolean   @default(false)
  postOptIn              Boolean   @default(true)
  phoneOptIn             Boolean   @default(false)
  communicationFrequency String?   @default("WEEKLY") // DAILY | WEEKLY | MONTHLY
  interestCategories     String[]  @default([]) // JSON array of interest categories
  isLotteryMember        Boolean   @default(false)
  lotteryMemberSince     DateTime?
  isArchived             Boolean   @default(false)
  archivedAt             DateTime?
  dateOfBirth            String?
  createdById            String
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organisation               Organisation?               @relation(fields: [organisationId], references: [id])
  createdBy                  User                        @relation("CreatedByUser", fields: [createdById], references: [id])
  tags                       ContactTag[]
  notes                      Note[]
  interactions               Interaction[]
  volunteerProfile           VolunteerProfile?
  giftAids                   GiftAid[]
  donations                  Donation[]
  eventAttendees             EventAttendee[]
  relationshipsFrom          ContactRelationship[]       @relation("RelationshipFrom")
  relationshipsTo            ContactRelationship[]       @relation("RelationshipTo")
  tributeGuardians           TributeFundGuardian[]
  eventOrders                EventOrder[]
  userAccount                User?                       @relation("UserLinkedContact")
  fundraisingPages           FundraisingPage[]
  payments                   Payment[]
  subscriptions              Subscription[]
  memberships                Membership[]
  legacies                   Legacy[]
  cases                      CaseRecord[]
  donorOpportunities         DonorOpportunity[]          @relation("DonorOpportunitiesContact")
  pledges                    Pledge[]                    @relation("PledgeContact")
  corporatePartnerships      CorporatePartnership[]      @relation("PartnershipContact")
  preferenceTokens           PreferenceToken[]
  smsMessages                SmsMessage[]                @relation("ContactSmsMessages")
  memberPortalTokens         MemberPortalToken[]
  autoTasks                  AutoTask[]                  @relation("AutoTaskContact")
  retailGiftAidNotifications RetailGiftAidNotification[]
  softCredits                SoftCredit[]
}

model Organisation {
  id           String   @id @default(cuid())
  name         String
  type         String? // Corporate | Foundation | Government | Trust | Other
  website      String?
  phone        String?
  email        String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  postcode     String?
  country      String?
  parentId     String? // FK → Organisation (parent/child hierarchy)
  isSupplier   Boolean  @default(false)
  isArchived   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent           Organisation?          @relation("OrgHierarchy", fields: [parentId], references: [id])
  children         Organisation[]         @relation("OrgHierarchy")
  contacts         Contact[]
  grants           Grant[]
  partnerships     CorporatePartnership[] @relation("CorporatePartnerships")
  eventIncomeLines EventIncomeLine[]      @relation("IncomeLineOrg")
  eventCostLines   EventCostLine[]        @relation("CostLineOrg")
  eventSponsors    EventSponsor[]         @relation("SponsorOrg")
}

model Tag {
  id     String  @id @default(cuid())
  name   String  @unique
  colour String?

  contacts         ContactTag[]
  campaignSegments CampaignSegment[]
}

model ContactTag {
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model Interaction {
  id          String   @id @default(cuid())
  contactId   String
  type        String
  subject     String
  description String?
  date        DateTime
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy User    @relation("InteractionCreatedBy", fields: [createdById], references: [id])
}

model Note {
  id          String   @id @default(cuid())
  contactId   String
  content     String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy User    @relation("NoteCreatedBy", fields: [createdById], references: [id])
}

// ============================================
// VOLUNTEER MODULE
// ============================================

model VolunteerProfile {
  id                  String   @id @default(cuid())
  contactId           String   @unique
  userId              String?  @unique
  status              String   @default("APPLICANT")
  startDate           String?
  endDate             String?
  desiredHoursPerWeek Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  contact               Contact                @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user                  User?                  @relation("UserVolunteerProfile", fields: [userId], references: [id])
  departments           VolunteerDepartment[]
  skills                VolunteerSkill[]
  availability          Availability[]
  specialConsiderations SpecialConsideration[]
  hoursLogs             VolunteerHoursLog[]
  activityRecords       ActivityRecord[]
  assignments           Assignment[]
  reminders             Reminder[]
  broadcastResponses    BroadcastResponse[]
  assignmentReminders   AssignmentReminder[]
  trainings             VolunteerTraining[]
  routesAssigned        CollectionRoute[]      @relation("RouteAssignedTo")
  runsAssigned          CollectionRun[]        @relation("RunAssignedTo")
  dbsChecks             DBSCheck[]
  drivingLicence        DrivingLicence?
  onboardingSteps       OnboardingStep[]
}

model VolunteerDepartment {
  volunteerId  String
  departmentId String

  volunteer  VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  department Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([volunteerId, departmentId])
}

model VolunteerSkill {
  id           String    @id @default(cuid())
  volunteerId  String
  skillId      String
  proficiency  String    @default("BEGINNER")
  verifiedById String?
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  volunteer  VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  skill      Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)
  verifiedBy User?            @relation("SkillVerifiedBy", fields: [verifiedById], references: [id])

  @@unique([volunteerId, skillId])
}

model Availability {
  id           String   @id @default(cuid())
  volunteerId  String
  dayOfWeek    String
  startTime    String
  endTime      String
  isRecurring  Boolean  @default(true)
  specificDate String?
  notes        String?
  updatedAt    DateTime @updatedAt

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
}

model SpecialConsideration {
  id             String   @id @default(cuid())
  volunteerId    String
  category       String
  description    String
  accommodations String?
  isConfidential Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
}

model VolunteerHoursLog {
  id           String   @id @default(cuid())
  volunteerId  String
  departmentId String?
  date         String
  hours        Float
  description  String?
  verifiedById String?
  status       String   @default("LOGGED")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  volunteer  VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  department Department?      @relation(fields: [departmentId], references: [id])
  verifiedBy User?            @relation("VerifiedByUser", fields: [verifiedById], references: [id])
}

model ActivityRecord {
  id           String   @id @default(cuid())
  volunteerId  String
  type         String
  title        String
  description  String?
  date         DateTime
  departmentId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  volunteer  VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  department Department?      @relation(fields: [departmentId], references: [id])
}

model Reminder {
  id          String    @id @default(cuid())
  volunteerId String
  type        String
  title       String
  message     String?
  triggerDate DateTime
  isAutomatic Boolean   @default(false)
  isSent      Boolean   @default(false)
  sentAt      DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  createdBy User             @relation("ReminderCreatedBy", fields: [createdById], references: [id])
}

// ============================================
// ASSIGNMENT & SCHEDULING
// ============================================

model Assignment {
  id           String   @id @default(cuid())
  volunteerId  String
  departmentId String
  title        String
  description  String?
  date         String
  startTime    String
  endTime      String
  status       String   @default("SCHEDULED")
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  volunteer  VolunteerProfile     @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  department Department           @relation(fields: [departmentId], references: [id])
  createdBy  User                 @relation("AssignmentCreatedBy", fields: [createdById], references: [id])
  reminders  AssignmentReminder[]
}

model AssignmentReminder {
  id             String    @id @default(cuid())
  assignmentId   String
  volunteerId    String
  reminderTime   DateTime
  channel        String
  status         String    @default("PENDING")
  sentAt         DateTime?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  assignment Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  volunteer  VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
}

// ============================================
// NOTIFICATION SYSTEM
// ============================================

model Notification {
  id          String    @id @default(cuid())
  recipientId String
  type        String
  title       String
  body        String
  link        String?
  channel     String
  status      String    @default("QUEUED")
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  recipient User @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
}

// Push device tokens for mobile app notifications
model PushDevice {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique // FCM or Expo push token
  platform   String   @default("EXPO") // EXPO | FCM | APNS
  deviceName String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// BROADCAST / URGENT COVER
// ============================================

model Broadcast {
  id              String    @id @default(cuid())
  title           String
  message         String
  urgency         String    @default("NORMAL")
  departmentId    String?
  targetDate      String
  targetStartTime String
  targetEndTime   String
  status          String    @default("OPEN")
  maxRespondents  Int       @default(1)
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  expiresAt       DateTime
  filledAt        DateTime?

  department Department?         @relation(fields: [departmentId], references: [id])
  createdBy  User                @relation("BroadcastCreatedBy", fields: [createdById], references: [id])
  skills     BroadcastSkill[]
  responses  BroadcastResponse[]
}

model BroadcastSkill {
  broadcastId String
  skillId     String

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  skill     Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([broadcastId, skillId])
}

model BroadcastResponse {
  id            String    @id @default(cuid())
  broadcastId   String
  volunteerId   String
  response      String
  message       String?
  respondedAt   DateTime  @default(now())
  confirmedById String?
  confirmedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  broadcast   Broadcast        @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  volunteer   VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  confirmedBy User?            @relation("BroadcastConfirmedBy", fields: [confirmedById], references: [id])
}

// ============================================
// CONTACT RELATIONSHIPS
// ============================================

model ContactRelationship {
  id            String   @id @default(cuid())
  fromContactId String
  toContactId   String
  type          String // SPOUSE | PARENT | CHILD | SIBLING | EMPLOYER | EMPLOYEE | FRIEND | GUARDIAN | OTHER
  description   String?
  createdAt     DateTime @default(now())

  fromContact Contact @relation("RelationshipFrom", fields: [fromContactId], references: [id], onDelete: Cascade)
  toContact   Contact @relation("RelationshipTo", fields: [toContactId], references: [id], onDelete: Cascade)

  @@unique([fromContactId, toContactId, type])
}

// ============================================
// GIFT AID MODULE
// ============================================

model GiftAid {
  id                  String    @id @default(cuid())
  contactId           String
  declarationDate     DateTime
  startDate           DateTime
  endDate             DateTime? // null = ongoing
  status              String    @default("ACTIVE") // ACTIVE | EXPIRED | CANCELLED
  type                String    @default("STANDARD") // STANDARD | RETAIL
  documentUrl         String? // scanned declaration document
  declarationImageUrl String? // uploaded photo/scan of paper declaration
  source              String    @default("MANUAL") // MANUAL | DIGITAL | PAPER
  // Digital declaration fields
  digitalToken        String?   @unique // unique token for digital declaration URL
  digitalSignedAt     DateTime? // when the donor digitally signed
  digitalSignedIp     String? // IP address for audit trail
  digitalSignedName   String? // name as typed by donor (e-signature)
  notes               String?
  createdById         String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  // Backdating
  backdateFrom        DateTime? // earliest date this declaration covers
  // Cessation
  cessationReason     String? // DONOR_REQUEST | DECEASED | HMRC_INSTRUCTION | OTHER
  cessationDate       DateTime?
  cessationNotes      String?

  contact   Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy User           @relation("GiftAidCreatedBy", fields: [createdById], references: [id])
  pauses    GiftAidPause[]
}

model GiftAidPause {
  id          String    @id @default(cuid())
  giftAidId   String
  pauseFrom   DateTime
  pauseUntil  DateTime? // null = indefinite
  reason      String?
  resumedAt   DateTime?
  resumedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  giftAid GiftAid @relation(fields: [giftAidId], references: [id], onDelete: Cascade)

  @@index([giftAidId])
}

// ============================================
// FUNDRAISING & DONATIONS MODULE
// ============================================

model LedgerCode {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  donations           Donation[]
  events              Event[]
  campaigns           Campaign[]
  donationTypes       DonationType[]       @relation("DonationTypeDefaultLedger")
  sageAccountMappings SageAccountMapping[]
  xeroAccountMappings XeroAccountMapping[] @relation("XeroAccountMappings")
}

model Donation {
  id             String   @id @default(cuid())
  contactId      String
  amount         Float
  currency       String   @default("GBP")
  type           String // DONATION | PAYMENT | GIFT | EVENT_FEE | SPONSORSHIP | LEGACY | GRANT | IN_KIND
  method         String? // CASH | CHEQUE | CARD | DIRECT_DEBIT | STANDING_ORDER | BANK_TRANSFER | ONLINE | OTHER
  reference      String? // payment reference / receipt number
  date           DateTime
  ledgerCodeId   String?
  campaignId     String?
  eventId        String?
  isGiftAidable  Boolean  @default(false)
  giftAidClaimed Boolean  @default(false)
  isRetail       Boolean  @default(false) // true for goods sold via charity shops (EPOS)
  notes          String?
  status         String   @default("RECEIVED") // RECEIVED | PENDING | REFUNDED | CANCELLED
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contact        Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ledgerCode     LedgerCode?    @relation(fields: [ledgerCodeId], references: [id])
  campaign       Campaign?      @relation(fields: [campaignId], references: [id])
  event          Event?         @relation(fields: [eventId], references: [id])
  createdBy      User           @relation("DonationCreatedBy", fields: [createdById], references: [id])
  pledgePayment  PledgePayment? @relation("PledgePayment")
  bankDocumentId String?
  bankDocument   BankDocument?  @relation(fields: [bankDocumentId], references: [id])
  softCredits    SoftCredit[]
}

model DonationType {
  id                  String      @id @default(cuid())
  name                String      @unique
  label               String // display label e.g. "Donation", "Event Fee"
  isGiftAidEligible   Boolean     @default(false)
  isSystem            Boolean     @default(false)
  isActive            Boolean     @default(true)
  sortOrder           Int         @default(0)
  defaultLedgerCodeId String?
  defaultLedgerCode   LedgerCode? @relation("DonationTypeDefaultLedger", fields: [defaultLedgerCodeId], references: [id])
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model PaymentMethod {
  id        String   @id @default(cuid())
  name      String   @unique
  isSystem  Boolean  @default(false)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BankDocument {
  id          String   @id @default(cuid())
  reference   String   @unique
  date        DateTime @default(now())
  status      String   @default("OPEN") // OPEN | SUBMITTED | CLOSED
  notes       String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User       @relation("BankDocCreatedBy", fields: [createdById], references: [id])
  donations Donation[]
}

model SoftCredit {
  id         String   @id @default(cuid())
  donationId String
  contactId  String
  amount     Float
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  donation Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

// ============================================
// EVENT MANAGEMENT MODULE
// ============================================

model EventType {
  id        String   @id @default(cuid())
  name      String   @unique
  colour    String   @default("#6366f1") // hex colour for badges
  isSystem  Boolean  @default(false) // true = predefined, false = custom
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]
}

model Event {
  id           String    @id @default(cuid())
  name         String
  description  String?
  type         String? // legacy — kept for backward compat
  eventTypeId  String?
  startDate    DateTime
  endDate      DateTime?
  location     String?
  capacity     Int?
  campaignId   String?
  ledgerCodeId String?
  status       String    @default("PLANNED") // PLANNED | OPEN | IN_PROGRESS | COMPLETED | CANCELLED
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  eventType        EventType?             @relation(fields: [eventTypeId], references: [id])
  campaign         Campaign?              @relation(fields: [campaignId], references: [id])
  ledgerCode       LedgerCode?            @relation(fields: [ledgerCodeId], references: [id])
  createdBy        User                   @relation("EventCreatedBy", fields: [createdById], references: [id])
  attendees        EventAttendee[]
  donations        Donation[]
  merchandise      EventMerchandise[]
  registrationForm EventRegistrationForm?
  orders           EventOrder[]
  fundraisingPages FundraisingPage[]
  incomeLines      EventIncomeLine[]
  costLines        EventCostLine[]
  finance          EventFinance?
  sponsors         EventSponsor[]
}

// ============================================
// EVENT P&L / FINANCE
// ============================================

model EventFinance {
  id           String    @id @default(cuid())
  eventId      String    @unique
  incomeTarget Float     @default(0) // Target total income (£)
  costTarget   Float     @default(0) // Target total costs (£)
  profitTarget Float     @default(0) // Target profit (£)
  finalTakings Float? // Final total after event completion
  completedAt  DateTime?
  notes        String? // Completion notes
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventIncomeLine {
  id             String   @id @default(cuid())
  eventId        String
  organisationId String? // Optional link to supplier organisation
  category       String // REGISTRATION_FEES | TICKET_SALES | BUCKET_COLLECTION | DONATIONS_ON_DAY | PITCH_FEES | SPONSORSHIP | MERCHANDISE | RAFFLE | AUCTION | OTHER
  label          String // Display label e.g. "Early Bird Tickets"
  description    String?
  estimated      Float    @default(0) // Budgeted / estimated amount
  actual         Float    @default(0) // Actual amount received
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organisation Organisation? @relation("IncomeLineOrg", fields: [organisationId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([organisationId])
}

model EventCostLine {
  id             String   @id @default(cuid())
  eventId        String
  organisationId String? // Optional link to supplier organisation
  category       String // VENUE_HIRE | CATERING | ENTERTAINMENT | EQUIPMENT | MARKETING | INSURANCE | STAFFING | TRANSPORT | PRINTING | LICENSES | DECORATIONS | FIRST_AID | SECURITY | WASTE_DISPOSAL | OTHER
  label          String // Display label e.g. "Main Hall Hire"
  description    String?
  estimated      Float    @default(0) // Budgeted / estimated amount
  actual         Float    @default(0) // Actual amount paid
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organisation Organisation? @relation("CostLineOrg", fields: [organisationId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([organisationId])
}

// ============================================
// FUNDRAISING PAGES (JustGiving, GoFundMe, etc.)
// ============================================
// A fundraising page belongs to a person (Contact), not an event.
// A supporter creates their own page — they may do multiple over the years.

model FundraisingPage {
  id           String    @id @default(cuid())
  contactId    String // the fundraiser — the person who created the page
  eventId      String? // optionally linked to a charity event
  platform     String    @default("JUSTGIVING") // JUSTGIVING | GOFUNDME | VIRGINMONEY | OTHER
  pageUrl      String // full URL to the page
  pageSlug     String // extracted slug for API calls
  title        String? // e.g. "Ross's 3000 Mile Bike Ride"
  targetAmount Float? // fundraising target
  totalRaised  Float     @default(0)
  giftAidTotal Float     @default(0)
  currency     String    @default("GBP")
  isActive     Boolean   @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contact   Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  event     Event?                @relation(fields: [eventId], references: [id])
  donations FundraisingDonation[]

  @@index([contactId])
  @@index([pageSlug])
}

model FundraisingDonation {
  id                  String   @id @default(cuid())
  fundraisingPageId   String
  externalId          String   @unique // JG donation ID etc. to prevent duplicates
  donorDisplayName    String? // public display name from the platform
  amount              Float
  currencyCode        String   @default("GBP")
  donationDate        DateTime
  message             String?
  estimatedTaxReclaim Float?
  isGiftAidEligible   Boolean  @default(false)
  imageUrl            String? // donor avatar from platform
  donationId          String? // linked to main Donation record in finance
  rawData             String? // full JSON from API
  syncedAt            DateTime @default(now())

  fundraisingPage FundraisingPage @relation(fields: [fundraisingPageId], references: [id], onDelete: Cascade)

  @@index([fundraisingPageId])
  @@index([donationDate])
}

model EventAttendee {
  id         String   @id @default(cuid())
  eventId    String
  contactId  String
  status     String   @default("REGISTERED") // REGISTERED | CONFIRMED | ATTENDED | NO_SHOW | CANCELLED
  ticketType String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([eventId, contactId])
}

model EventMerchandise {
  id           String   @id @default(cuid())
  eventId      String
  name         String
  description  String?
  quantity     Int      @default(0)
  unitPrice    Float?
  quantitySold Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventSponsor {
  id               String   @id @default(cuid())
  eventId          String
  organisationId   String?
  name             String // sponsor name (if no org link)
  logoUrl          String?
  sponsorshipLevel String   @default("MINOR") // HEADLINE | MAJOR | MINOR | IN_KIND
  amount           Float?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organisation Organisation? @relation("SponsorOrg", fields: [organisationId], references: [id], onDelete: SetNull)

  @@index([eventId])
}

model FinancialTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  incomeLines String? // JSON array of {category, label, estimated}
  costLines   String? // JSON array of {category, label, estimated}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// EVENT REGISTRATION FORMS
// ============================================

model EventRegistrationForm {
  id          String  @id @default(cuid())
  eventId     String  @unique
  title       String
  description String?

  // Branding
  logoUrl         String?
  primaryColor    String  @default("#4F46E5")
  accentColor     String  @default("#10B981")
  headerText      String?
  thankYouMessage String?

  // Settings
  isActive        Boolean @default(true)
  requiresPayment Boolean @default(true)
  allowDonations  Boolean @default(true)
  collectPhone    Boolean @default(true)
  collectAddress  Boolean @default(false)
  giftAidEnabled  Boolean @default(true)

  // Payment gateways
  stripeEnabled     Boolean @default(false)
  goCardlessEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event  Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items  EventFormItem[]
  orders EventOrder[]
}

model EventFormItem {
  id                String   @id @default(cuid())
  formId            String
  name              String
  description       String?
  type              String // REGISTRATION_FEE | MERCHANDISE | DONATION
  price             Float? // null for DONATION (user enters amount)
  isRequired        Boolean  @default(false)
  isGiftAidEligible Boolean  @default(false)
  maxQuantity       Int? // stock limit for merchandise
  sortOrder         Int      @default(0)
  options           String? // JSON for variants e.g. ["S","M","L","XL"]
  imageUrl          String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  form      EventRegistrationForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  lineItems OrderLineItem[]
}

model EventOrder {
  id          String @id @default(cuid())
  formId      String
  contactId   String
  eventId     String
  orderNumber String @unique

  // Totals
  subtotal     Float
  giftAidTotal Float @default(0)
  totalAmount  Float

  // Status
  status           String  @default("PENDING") // PENDING | CONFIRMED | CANCELLED | REFUNDED
  paymentStatus    String  @default("UNPAID") // UNPAID | PAID | PARTIAL | REFUNDED | FREE
  paymentMethod    String? // STRIPE | GOCARDLESS | FREE
  paymentReference String? // external payment ID

  // Attendee info
  attendeeName    String
  attendeeEmail   String
  attendeePhone   String?
  attendeeAddress String?

  // Gift Aid
  giftAidDeclared Boolean @default(false)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  form      EventRegistrationForm @relation(fields: [formId], references: [id])
  contact   Contact               @relation(fields: [contactId], references: [id])
  event     Event                 @relation(fields: [eventId], references: [id])
  lineItems OrderLineItem[]
  payments  EventPayment[]
}

model OrderLineItem {
  id                String   @id @default(cuid())
  orderId           String
  itemId            String
  quantity          Int      @default(1)
  unitPrice         Float
  total             Float
  isGiftAidEligible Boolean  @default(false)
  variant           String? // e.g. "Size: L"
  createdAt         DateTime @default(now())

  order EventOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item  EventFormItem @relation(fields: [itemId], references: [id])
}

model EventPayment {
  id        String   @id @default(cuid())
  orderId   String
  amount    Float
  method    String // STRIPE | GOCARDLESS
  status    String // PENDING | SUCCEEDED | FAILED | REFUNDED
  reference String? // external payment ID (pi_xxx, pm_xxx)
  metadata  String? // JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order EventOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ============================================
// MARKETING & CAMPAIGNS MODULE
// ============================================

model Campaign {
  id           String    @id @default(cuid())
  name         String
  description  String?
  type         String? // APPEAL | MAIL | EMAIL | EVENT | LEGACY | CORPORATE | OTHER
  ledgerCodeId String?
  startDate    DateTime?
  endDate      DateTime?
  budgetTarget Float?
  actualRaised Float     @default(0)
  status       String    @default("DRAFT") // DRAFT | ACTIVE | PAUSED | COMPLETED | CANCELLED
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ledgerCode         LedgerCode?        @relation(fields: [ledgerCodeId], references: [id])
  createdBy          User               @relation("CampaignCreatedBy", fields: [createdById], references: [id])
  events             Event[]
  donations          Donation[]
  segments           CampaignSegment[]
  donorOpportunities DonorOpportunity[] @relation("DonorOpportunitiesCampaign")
  pledges            Pledge[]           @relation("PledgeCampaign")
}

model CampaignSegment {
  id         String   @id @default(cuid())
  campaignId String
  tagId      String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([campaignId, tagId])
}

model SavedSegment {
  id          String   @id @default(cuid())
  name        String
  description String?
  filters     String // JSON object with filter criteria
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation("SavedSegmentCreatedBy", fields: [createdById], references: [id])

  @@index([createdById])
}

// ============================================
// COLLECTION TINS MODULE
// ============================================

model TinLocation {
  id           String   @id @default(cuid())
  name         String
  address      String?
  city         String?
  postcode     String?
  postcodeArea String? // e.g. "SY11 1", "SY11 2" — auto-derived from postcode
  type         String   @default("OTHER") // SHOP | PUB | RESTAURANT | OFFICE | SCHOOL | CHURCH | OTHER
  contactName  String?
  contactPhone String?
  latitude     Float?
  longitude    Float?
  isActive     Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tins       CollectionTin[]
  routeStops RouteStop[]

  @@index([postcodeArea])
}

model CollectionTin {
  id              String    @id @default(cuid())
  tinNumber       String    @unique
  locationName    String
  locationAddress String?
  locationId      String?
  contactId       String? // FK → Contact (location contact person)
  status          String    @default("IN_STOCK") // IN_STOCK | DEPLOYED | RETURNED | LOST | STOLEN | RETIRED
  deployedAt      DateTime?
  returnedAt      DateTime?
  notes           String?
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  location          TinLocation?            @relation(fields: [locationId], references: [id])
  createdBy         User                    @relation("CollectionTinCreatedBy", fields: [createdById], references: [id])
  movements         CollectionTinMovement[]
  tinReturns        TinReturn[]
  deployedRunStops  RunStop[]               @relation("RunStopDeployedTin")
  collectedRunStops RunStop[]               @relation("RunStopCollectedTin")
}

model CollectionTinMovement {
  id        String   @id @default(cuid())
  tinId     String
  type      String // DEPLOYED | COLLECTED | COUNTED | LOST | STOLEN | RETURNED
  date      DateTime
  amount    Float? // amount collected (if counted)
  notes     String?
  routeId   String?
  stopId    String?
  createdAt DateTime @default(now())

  tin CollectionTin @relation(fields: [tinId], references: [id], onDelete: Cascade)
}

// Route = reusable template (a "round"), like a courier route with fixed stops
model CollectionRoute {
  id           String   @id @default(cuid())
  name         String
  description  String?
  tinCount     Int      @default(0) // how many fresh tins to take out
  assignedToId String? // default volunteer for this route
  createdById  String
  isActive     Boolean  @default(true)
  source       String   @default("MANUAL") // MANUAL | SUGGESTED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTo VolunteerProfile? @relation("RouteAssignedTo", fields: [assignedToId], references: [id])
  createdBy  User              @relation("RouteCreatedBy", fields: [createdById], references: [id])
  stops      RouteStop[]
  runs       CollectionRun[]

  @@index([isActive])
}

// RouteStop = a fixed stop on the route template (reused across runs)
model RouteStop {
  id           String   @id @default(cuid())
  routeId      String
  locationId   String
  sortOrder    Int      @default(0)
  parkingNotes String?
  accessNotes  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  route    CollectionRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  location TinLocation     @relation(fields: [locationId], references: [id])
  runStops RunStop[]

  @@index([routeId])
}

// CollectionRun = a specific instance of running a route on a date
model CollectionRun {
  id            String    @id @default(cuid())
  routeId       String
  status        String    @default("SCHEDULED") // SCHEDULED | IN_PROGRESS | COMPLETED | CANCELLED
  scheduledDate DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  assignedToId  String? // can override route default volunteer
  createdById   String
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  route      CollectionRoute   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  assignedTo VolunteerProfile? @relation("RunAssignedTo", fields: [assignedToId], references: [id])
  createdBy  User              @relation("RunCreatedBy", fields: [createdById], references: [id])
  runStops   RunStop[]
  tinReturns TinReturn[]

  @@index([routeId])
  @@index([status])
  @@index([scheduledDate])
}

// RunStop = per-run tracking of each stop (what was swapped, GPS, status)
model RunStop {
  id             String    @id @default(cuid())
  runId          String
  routeStopId    String
  status         String    @default("PENDING") // PENDING | COMPLETED | SKIPPED
  skipReason     String?
  deployedTinId  String?
  collectedTinId String?
  completedAt    DateTime?
  latitude       Float?
  longitude      Float?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  run          CollectionRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  routeStop    RouteStop      @relation(fields: [routeStopId], references: [id], onDelete: Cascade)
  deployedTin  CollectionTin? @relation("RunStopDeployedTin", fields: [deployedTinId], references: [id])
  collectedTin CollectionTin? @relation("RunStopCollectedTin", fields: [collectedTinId], references: [id])

  @@index([runId])
  @@index([routeStopId])
}

model TinReturn {
  id          String   @id @default(cuid())
  tinId       String
  runId       String?
  amount      Float
  countedById String
  returnedAt  DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())

  tin       CollectionTin  @relation(fields: [tinId], references: [id])
  run       CollectionRun? @relation(fields: [runId], references: [id])
  countedBy User           @relation("TinReturnCountedBy", fields: [countedById], references: [id])

  @@index([tinId])
  @@index([runId])
}

// ============================================
// TRIBUTE FUNDS MODULE
// ============================================

model TributeFund {
  id          String   @id @default(cuid())
  name        String
  type        String // TRADITIONAL | ROBIN (children's)
  description String?
  inMemoryOf  String? // name of person being remembered
  status      String   @default("ACTIVE") // ACTIVE | CLOSED
  totalRaised Float    @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy  User                   @relation("TributeFundCreatedBy", fields: [createdById], references: [id])
  guardians  TributeFundGuardian[]
  milestones TributeFundMilestone[]
}

model TributeFundGuardian {
  id            String   @id @default(cuid())
  tributeFundId String
  contactId     String
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())

  tributeFund TributeFund @relation(fields: [tributeFundId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([tributeFundId, contactId])
}

model TributeFundMilestone {
  id            String   @id @default(cuid())
  tributeFundId String
  title         String
  description   String?
  date          DateTime
  createdAt     DateTime @default(now())

  tributeFund TributeFund @relation(fields: [tributeFundId], references: [id], onDelete: Cascade)
}

// ============================================
// VOLUNTEER TRAINING MODULE
// ============================================

model TrainingCourse {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String?
  isMandatory    Boolean  @default(false)
  validityMonths Int? // how long certification lasts (null = never expires)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  volunteerTrainings  VolunteerTraining[]
  departmentTrainings DepartmentTraining[]
}

model VolunteerTraining {
  id             String    @id @default(cuid())
  volunteerId    String
  courseId       String
  status         String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLETED | EXPIRED
  completedDate  DateTime?
  expiryDate     DateTime?
  certificateUrl String?
  verifiedById   String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  volunteer  VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  course     TrainingCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  verifiedBy User?            @relation("TrainingVerifiedBy", fields: [verifiedById], references: [id])

  @@unique([volunteerId, courseId])
}

model DBSCheck {
  id                String   @id @default(cuid())
  volunteerId       String
  checkDate         DateTime
  expiryDate        DateTime
  certificateNumber String?
  level             String   @default("BASIC") // BASIC | STANDARD | ENHANCED
  status            String   @default("PENDING") // PENDING | CLEARED | ISSUES_FOUND | EXPIRED
  cost              Float?
  documentUrl       String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@index([volunteerId])
  @@index([expiryDate])
}

model DrivingLicence {
  id            String    @id @default(cuid())
  volunteerId   String    @unique
  licenceNumber String?
  expiryDate    DateTime?
  categories    String? // comma-separated: B, C1, etc.
  verifiedAt    DateTime?
  verifiedById  String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
}

model OnboardingStep {
  id            String    @id @default(cuid())
  volunteerId   String
  stepName      String // APPLICATION_RECEIVED | DBS_SUBMITTED | DBS_CLEARED | INDUCTION | TRAINING_ASSIGNED | TRAINING_COMPLETED | FULLY_ONBOARDED
  completedAt   DateTime?
  completedById String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([volunteerId, stepName])
}

model DepartmentTraining {
  id           String   @id @default(cuid())
  departmentId String
  courseId     String
  createdAt    DateTime @default(now())

  department Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  course     TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([departmentId, courseId])
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String // CREATE | UPDATE | DELETE | ARCHIVE | LOGIN | LOGOUT | EXPORT | MERGE | ANONYMISE
  entityType String // Contact | Organisation | Volunteer | Donation | etc.
  entityId   String?
  details    String? // JSON with changed fields
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation("AuditLogUser", fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// DATA MANAGEMENT / GDPR
// ============================================

model DataRetentionPolicy {
  id              String   @id @default(cuid())
  entityType      String   @unique // Contact | Donation | etc.
  retentionMonths Int // how many months to keep records
  action          String // ARCHIVE | ANONYMISE | DELETE
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// DPIA — Data Protection Impact Assessment
// ============================================

model Dpia {
  id                     String    @id @default(cuid())
  title                  String
  description            String
  projectOrSystem        String // which system/project this covers (e.g. "Parity CRM CRM")
  dataController         String // org name
  dpoName                String? // DPO who will sign off
  dpoEmail               String?
  csoName                String? // Clinical Safety Officer name
  csoSignedOff           Boolean   @default(false)
  csoSignedOffAt         DateTime?
  status                 String    @default("DRAFT") // DRAFT | IN_REVIEW | DPO_REVIEW | APPROVED | REJECTED | REQUIRES_UPDATE
  legalBasis             String? // CONSENT | PUBLIC_TASK | LEGITIMATE_INTEREST | LEGAL_OBLIGATION | VITAL_INTEREST | CONTRACT
  dataSubjects           String? // e.g. "Patients, Donors, Volunteers, Staff"
  dataCategories         String? // e.g. "Contact details, Health data, Financial data"
  specialCategories      Boolean   @default(false) // true if processing special category data (health, ethnicity, etc.)
  dataMinimisation       String? // how data minimisation is achieved
  retentionPeriod        String? // how long data is retained
  securityMeasures       String? // encryption, access controls, etc.
  internationalTransfers Boolean   @default(false)
  transferSafeguards     String? // if international transfers, what safeguards
  consultationRequired   Boolean   @default(false) // whether ICO consultation is needed
  dpoAdvice              String? // DPO's written advice
  dpoSignedOff           Boolean   @default(false)
  dpoSignedOffAt         DateTime?
  dpoOverruled           Boolean   @default(false)
  overruleReason         String? // if DPO advice overruled, document why
  reviewDate             DateTime? // when to next review this DPIA
  createdById            String
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  createdBy User       @relation("DpiaCreatedBy", fields: [createdById], references: [id])
  risks     DpiaRisk[]
}

model DpiaRisk {
  id           String   @id @default(cuid())
  dpiaId       String
  description  String // what is the risk
  likelihood   String // LOW | MEDIUM | HIGH | VERY_HIGH
  severity     String // LOW | MEDIUM | HIGH | VERY_HIGH
  riskLevel    String // LOW | MEDIUM | HIGH | VERY_HIGH (calculated or set)
  mitigation   String? // how this risk is mitigated
  residualRisk String? // LOW | MEDIUM | HIGH | VERY_HIGH after mitigation
  riskOwner    String? // who is responsible
  status       String   @default("OPEN") // OPEN | MITIGATED | ACCEPTED | TRANSFERRED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dpia Dpia @relation(fields: [dpiaId], references: [id], onDelete: Cascade)
}

// ============================================
// DATA BREACH LOG
// ============================================

model DataBreach {
  id                     String    @id @default(cuid())
  title                  String
  description            String
  discoveredAt           DateTime
  reportedAt             DateTime? // when reported to DPO
  icoNotified            Boolean   @default(false) // reported to ICO within 72 hours?
  icoNotifiedAt          DateTime?
  icoReference           String? // ICO reference number
  dataSubjectsNotified   Boolean   @default(false)
  dataSubjectsNotifiedAt DateTime?
  severity               String    @default("LOW") // LOW | MEDIUM | HIGH | CRITICAL
  category               String? // CONFIDENTIALITY | INTEGRITY | AVAILABILITY
  dataSubjectsAffected   Int? // approximate number
  dataTypesAffected      String? // e.g. "Contact details, Health data"
  cause                  String? // e.g. "Phishing, Misconfiguration, Insider"
  containmentActions     String?
  remediationActions     String?
  lessonsLearned         String?
  status                 String    @default("OPEN") // OPEN | CONTAINED | INVESTIGATING | RESOLVED | CLOSED
  dpoReview              String? // DPO's assessment
  createdById            String
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  createdBy User @relation("BreachCreatedBy", fields: [createdById], references: [id])
}

// ============================================
// SUBJECT ACCESS REQUESTS (SAR)
// ============================================

model SubjectAccessRequest {
  id               String    @id @default(cuid())
  requesterName    String
  requesterEmail   String?
  requesterPhone   String?
  contactId        String? // FK → Contact (if matched to a contact)
  requestDate      DateTime
  dueDate          DateTime // must respond within 1 calendar month
  description      String? // what data they're requesting
  idVerified       Boolean   @default(false) // identity verification completed
  idVerifiedAt     DateTime?
  status           String    @default("RECEIVED") // RECEIVED | VERIFIED | IN_PROGRESS | READY | SENT | CLOSED | REFUSED
  refusalReason    String? // if refused, why (must be a valid exemption)
  extensionApplied Boolean   @default(false) // extended by 2 months for complex requests
  extensionReason  String?
  responseNotes    String?
  dataSentAt       DateTime?
  dataSentMethod   String? // EMAIL | POST | PORTAL
  assignedToId     String? // FK → User (staff handling the SAR)
  createdById      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignedTo User? @relation("SarAssignedTo", fields: [assignedToId], references: [id])
  createdBy  User  @relation("SarCreatedBy", fields: [createdById], references: [id])
}

// ============================================
// ROPA — Record of Processing Activities (Article 30)
// ============================================

model ProcessingActivity {
  id                     String    @id @default(cuid())
  name                   String // e.g. "Donor Contact Management"
  purpose                String // why this processing happens
  legalBasis             String // CONSENT | PUBLIC_TASK | LEGITIMATE_INTEREST | LEGAL_OBLIGATION | VITAL_INTEREST | CONTRACT
  dataController         String // org name
  dataProcessor          String? // if using a processor (e.g. Mailchimp)
  dataSubjectCategories  String // e.g. "Donors, Volunteers"
  dataCategories         String // e.g. "Name, Email, Phone, Address"
  specialCategories      String? // e.g. "Health data, Disability info"
  recipientCategories    String? // who data is shared with
  internationalTransfers Boolean   @default(false)
  transferSafeguards     String?
  retentionPeriod        String // e.g. "7 years after last interaction"
  securityMeasures       String? // e.g. "Encrypted at rest, role-based access"
  dpaInPlace             Boolean   @default(false) // Data Processing Agreement
  dpaReference           String? // reference number for the DPA
  lastReviewDate         DateTime?
  nextReviewDate         DateTime?
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

// ============================================
// INFORMATION ASSET REGISTER
// ============================================

model InformationAsset {
  id                  String    @id @default(cuid())
  name                String // e.g. "CRM Database", "Volunteer Records"
  description         String?
  assetOwner          String // person responsible
  assetType           String // DATABASE | FILE_SYSTEM | CLOUD_SERVICE | PAPER | APPLICATION | EMAIL
  location            String? // where is it stored
  dataClassification  String    @default("OFFICIAL") // OFFICIAL | OFFICIAL_SENSITIVE | SECRET
  personalData        Boolean   @default(false)
  specialCategoryData Boolean   @default(false)
  riskLevel           String    @default("LOW") // LOW | MEDIUM | HIGH | CRITICAL
  encryptionAtRest    Boolean   @default(false)
  encryptionInTransit Boolean   @default(false)
  accessControls      String? // who has access
  backupFrequency     String? // e.g. "Daily", "Weekly"
  retentionPeriod     String?
  disposalMethod      String? // how it's securely destroyed
  lastReviewDate      DateTime?
  nextReviewDate      DateTime?
  notes               String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ============================================
// CLINICAL SAFETY — DCB0129/DCB0160 Hazard Log
// ============================================

model ClinicalHazard {
  id                 String    @id @default(cuid())
  hazardNumber       String    @unique // e.g. "HAZ-001"
  name               String
  description        String
  cause              String? // what causes this hazard
  effect             String? // what happens if hazard occurs
  category           String? // PATIENT_SAFETY | DATA_LOSS | SYSTEM_FAILURE | ACCESS_CONTROL | CLINICAL_DECISION | OTHER
  initialSeverity    String // CATASTROPHIC | MAJOR | CONSIDERABLE | SIGNIFICANT | MINOR
  initialLikelihood  String // VERY_HIGH | HIGH | MEDIUM | LOW | VERY_LOW
  initialRiskLevel   String // calculated from severity x likelihood
  controls           String? // what controls are in place
  residualSeverity   String?
  residualLikelihood String?
  residualRiskLevel  String?
  riskAcceptability  String    @default("UNACCEPTABLE") // ACCEPTABLE | TOLERABLE | UNACCEPTABLE
  status             String    @default("OPEN") // OPEN | MITIGATED | CLOSED | TRANSFERRED
  assignedTo         String? // who is responsible
  csoReview          String? // Clinical Safety Officer review notes
  csoSignedOff       Boolean   @default(false)
  csoSignedOffAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// ============================================
// CONSENT AUDIT TRAIL
// ============================================

model ConsentRecord {
  id            String   @id @default(cuid())
  contactId     String
  consentType   String // POST | EMAIL | PHONE | SMS | DATA_PROCESSING | MARKETING | RESEARCH
  action        String // GRANTED | WITHDRAWN | UPDATED
  previousValue Boolean?
  newValue      Boolean
  source        String? // WEB_FORM | PHONE | LETTER | IN_PERSON | SYSTEM
  evidenceUrl   String? // link to scanned form etc.
  notes         String?
  recordedById  String // FK → User who recorded this
  recordedAt    DateTime @default(now())

  recordedBy User @relation("ConsentRecordedBy", fields: [recordedById], references: [id])

  @@index([contactId])
  @@index([consentType])
  @@index([recordedAt])
}

// ============================================
// EMAIL PROVIDER CONFIGURATION
// ============================================

model EmailProvider {
  id        String  @id @default(cuid())
  name      String // Display name e.g. "Our SendGrid"
  provider  String // SENDGRID | SES | MAILGUN | MAILCHIMP
  isActive  Boolean @default(true)
  isDefault Boolean @default(false)

  // Credentials (encrypted at rest via application layer)
  apiKey String? // SendGrid API key or Mailgun API key
  region String? // SES region e.g. "eu-west-1", Mailgun region "EU" or "US"
  domain String? // Mailgun sending domain

  // SES-specific
  accessKeyId     String? // AWS access key
  secretAccessKey String? // AWS secret key

  // Sender settings
  fromEmail    String // e.g. "noreply@charity.org"
  fromName     String // e.g. "Our Charity"
  replyToEmail String? // optional reply-to address

  // Status
  lastTestedAt   DateTime?
  lastTestResult String? // "success" or error message

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  createdBy User @relation("EmailProviderCreatedBy", fields: [createdById], references: [id])

  @@index([isDefault])
}

// ============================================
// PAYMENT PROCESSING MODULE
// ============================================

model PaymentProvider {
  id                   String   @id @default(cuid())
  name                 String
  provider             String // STRIPE | GOCARDLESS
  isActive             Boolean  @default(true)
  isDefault            Boolean  @default(false)
  stripeSecretKey      String?
  stripePublishableKey String?
  stripeWebhookSecret  String?
  gcAccessToken        String?
  gcEnvironment        String? // SANDBOX | LIVE
  gcWebhookSecret      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  createdById          String

  createdBy     User           @relation("PaymentProviderCreatedBy", fields: [createdById], references: [id])
  payments      Payment[]
  subscriptions Subscription[]

  @@index([isDefault])
}

model Payment {
  id             String    @id @default(cuid())
  contactId      String
  amount         Float
  currency       String    @default("GBP")
  status         String    @default("PENDING") // PENDING | SUCCEEDED | FAILED | REFUNDED | CANCELLED
  type           String // ONE_OFF | SUBSCRIPTION | EVENT_FEE | MEMBERSHIP_FEE
  method         String? // CARD | DIRECT_DEBIT | BANK_TRANSFER
  providerId     String?
  externalId     String?
  externalUrl    String?
  donationId     String?
  subscriptionId String?
  membershipId   String?
  description    String?
  metadata       String?
  failureReason  String?
  paidAt         DateTime?
  refundedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  contact      Contact          @relation(fields: [contactId], references: [id])
  provider     PaymentProvider? @relation(fields: [providerId], references: [id])
  subscription Subscription?    @relation(fields: [subscriptionId], references: [id])

  @@index([contactId])
  @@index([externalId])
  @@index([status])
}

model Subscription {
  id              String    @id @default(cuid())
  contactId       String
  amount          Float
  currency        String    @default("GBP")
  frequency       String // WEEKLY | MONTHLY | QUARTERLY | ANNUALLY
  status          String    @default("ACTIVE") // ACTIVE | PAUSED | CANCELLED | EXPIRED
  type            String // DONATION | MEMBERSHIP
  providerId      String?
  externalId      String?
  startDate       DateTime
  nextPaymentDate DateTime?
  cancelledAt     DateTime?
  donationId      String?
  membershipId    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contact  Contact          @relation(fields: [contactId], references: [id])
  provider PaymentProvider? @relation(fields: [providerId], references: [id])
  payments Payment[]

  @@index([contactId])
  @@index([status])
}

// ============================================
// MEMBERSHIPS MODULE
// ============================================

model MembershipType {
  id                  String   @id @default(cuid())
  name                String   @unique
  description         String?
  price               Float
  currency            String   @default("GBP")
  duration            Int      @default(12) // months
  benefits            String?
  isActive            Boolean  @default(true)
  sortOrder           Int      @default(0)
  renewalPeriodMonths Int      @default(12) // Renewal period in months
  renewalGraceDays    Int      @default(30) // Grace period after expiration before marking as lapsed
  autoRenewEnabled    Boolean  @default(true) // Whether auto-renewal is enabled for this membership type
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships Membership[]
}

model Membership {
  id               String    @id @default(cuid())
  contactId        String
  membershipTypeId String
  memberNumber     String    @unique
  status           String    @default("ACTIVE") // ACTIVE | EXPIRED | CANCELLED | PENDING | LAPSED
  startDate        DateTime
  endDate          DateTime
  renewalDate      DateTime?
  lastRenewalDate  DateTime? // Date of the last successful renewal
  autoRenew        Boolean   @default(false)
  amountPaid       Float?
  paymentMethod    String?
  paymentReference String?
  notes            String?
  cancelledAt      DateTime?
  cancelReason     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  contact          Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  membershipType   MembershipType      @relation(fields: [membershipTypeId], references: [id])
  renewals         MembershipRenewal[]
  renewalReminders RenewalReminder[]

  @@index([contactId])
  @@index([status])
  @@index([endDate])
}

model MembershipRenewal {
  id               String   @id @default(cuid())
  membershipId     String
  fromDate         DateTime
  toDate           DateTime
  amount           Float
  paymentMethod    String?
  paymentReference String?
  renewedAt        DateTime @default(now())

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
}

model RenewalReminder {
  id           String   @id @default(cuid())
  membershipId String
  type         String // FIRST_REMINDER | SECOND_REMINDER | FINAL_REMINDER | EXPIRY_NOTICE | LAPSED_NOTICE
  sentAt       DateTime
  emailId      String? // Track which email was sent for audit purposes
  createdAt    DateTime @default(now())

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([membershipId])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// GIFT AID CLAIMS (HMRC)
// ============================================

model GiftAidClaim {
  id                    String    @id @default(cuid())
  claimReference        String    @unique
  claimType             String    @default("STANDARD") // STANDARD | RETAIL
  status                String    @default("DRAFT") // DRAFT | NOTIFICATIONS_SENT | READY | SUBMITTED | ACCEPTED | REJECTED | PARTIAL
  totalDonations        Float     @default(0)
  totalClaimable        Float     @default(0)
  donationCount         Int       @default(0)
  periodStart           DateTime
  periodEnd             DateTime
  submittedAt           DateTime?
  hmrcReference         String?
  hmrcResponse          String?
  acceptedAt            DateTime?
  rejectedAt            DateTime?
  rejectionReason       String?
  amountReceived        Float?
  receivedAt            DateTime?
  correlationId         String? // HMRC submission correlation ID for polling
  submissionXml         String? // Stored XML for audit
  responseXml           String? // HMRC response XML
  gasdsAmount           Float? // Small Donations Scheme amount if applicable
  isTestMode            Boolean   @default(false) // true = test submission, not sent to real HMRC
  submittedById         String? // User who submitted to HMRC
  notes                 String?
  // Retail Gift Aid notification workflow fields
  notificationsSentAt   DateTime? // When notifications were sent to donors
  notificationDeadline  DateTime? // 28 days after notifications sent
  notificationsSentById String? // User who triggered notifications
  createdById           String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  createdBy     User                        @relation("GiftAidClaimCreatedBy", fields: [createdById], references: [id])
  submittedBy   User?                       @relation("GiftAidClaimSubmittedBy", fields: [submittedById], references: [id])
  items         GiftAidClaimItem[]
  notifications RetailGiftAidNotification[]

  @@index([status])
  @@index([claimType])
}

model GiftAidClaimItem {
  id             String   @id @default(cuid())
  claimId        String
  donationId     String
  contactId      String
  donorName      String
  donorAddress   String?
  donorPostcode  String?
  donationDate   DateTime
  donationAmount Float
  giftAidAmount  Float
  status         String   @default("INCLUDED") // INCLUDED | EXCLUDED | ERROR
  errorReason    String?
  createdAt      DateTime @default(now())

  claim GiftAidClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([donationId])
}

// Tracks individual notifications sent to donors for Retail Gift Aid claims
model RetailGiftAidNotification {
  id             String    @id @default(cuid())
  claimId        String
  contactId      String
  contactName    String
  contactEmail   String?
  method         String // EMAIL | POST
  status         String    @default("PENDING") // PENDING | SENT | FAILED
  sentAt         DateTime?
  token          String    @unique @default(cuid()) // Unique token for opt-out/consent URLs
  optedOut       Boolean   @default(false)
  optOutAt       DateTime?
  optOutReason   String?
  emailConsented Boolean   @default(false) // Did they consent to email for future claims?
  emailConsentAt DateTime?
  createdAt      DateTime  @default(now())

  claim   GiftAidClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id])

  @@index([claimId])
  @@index([contactId])
  @@index([token])
}

// ============================================
// FORMS BUILDER MODULE
// ============================================

model Form {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  type              String // DONATION | SIGNUP | CONTACT | EVENT | VOLUNTEER | CUSTOM
  status            String   @default("DRAFT") // DRAFT | ACTIVE | PAUSED | ARCHIVED
  title             String
  description       String?
  logoUrl           String?
  primaryColor      String   @default("#4F46E5")
  thankYouMessage   String   @default("Thank you for your submission!")
  redirectUrl       String?
  collectPhone      Boolean  @default(false)
  collectAddress    Boolean  @default(false)
  consentRequired   Boolean  @default(true)
  consentText       String?  @default("I consent to being contacted about this submission")
  captchaEnabled    Boolean  @default(true)
  notifyEmail       String?
  suggestedAmounts  String?
  allowCustomAmount Boolean  @default(true)
  giftAidEnabled    Boolean  @default(false)
  recurringEnabled  Boolean  @default(false)
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  createdBy   User             @relation("FormCreatedBy", fields: [createdById], references: [id])
  fields      FormField[]
  submissions FormSubmission[]

  @@index([slug])
  @@index([status])
}

model FormField {
  id          String   @id @default(cuid())
  formId      String
  label       String
  type        String // TEXT | EMAIL | PHONE | TEXTAREA | SELECT | CHECKBOX | NUMBER | DATE | AMOUNT
  placeholder String?
  helpText    String?
  isRequired  Boolean  @default(false)
  options     String?
  sortOrder   Int      @default(0)
  isSystem    Boolean  @default(false)
  fieldKey    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
}

model FormSubmission {
  id              String    @id @default(cuid())
  formId          String
  contactId       String?
  data            String
  ipAddress       String?
  userAgent       String?
  referrer        String?
  amount          Float?
  isRecurring     Boolean   @default(false)
  giftAidDeclared Boolean   @default(false)
  status          String    @default("RECEIVED") // RECEIVED | PROCESSED | SPAM | ERROR
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([createdAt])
}

// ============================================
// GRANTS MODULE
// ============================================

model Grant {
  id                  String    @id @default(cuid())
  title               String
  funderName          String
  funderId            String?
  type                String    @default("TRUST") // TRUST | FOUNDATION | GOVERNMENT | CORPORATE | LOTTERY | OTHER
  status              String    @default("IDENTIFIED") // IDENTIFIED | RESEARCHING | APPLYING | SUBMITTED | SUCCESSFUL | UNSUCCESSFUL | REPORTING | COMPLETED
  amountRequested     Float?
  amountAwarded       Float?
  currency            String    @default("GBP")
  applicationDeadline DateTime?
  submittedDate       DateTime?
  decisionDate        DateTime?
  startDate           DateTime?
  endDate             DateTime?
  reportingDeadline   DateTime?
  description         String?
  purpose             String?
  conditions          String?
  contactPerson       String?
  contactEmail        String?
  reference           String?
  notes               String?
  createdById         String
  createdAt           DateTime  @default(now())
